# ================================================
# MARIFETBUL - LOCAL DEVELOPMENT ENVIRONMENT
# ================================================
# Development Environment Variables
# Copy this file to .env.local and update values

# ================================================
# APPLICATION CONFIGURATION (Development)
# ================================================
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=MarifetBul (Dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ================================================
# BACKEND API CONFIGURATION (Local Backend)
# ================================================
# Option 1: Local Spring Boot backend (default)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Option 2: Remote development backend
# NEXT_PUBLIC_API_URL=https://dev-api.marifetbul.com/api/v1

# ================================================
# PAYMENT CONFIGURATION (Stripe - Development)
# ================================================
# Use Stripe test mode keys for development
# Get your test keys from: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_51xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Test Cards:
# Success: 4242 4242 4242 4242
# Requires 3D Secure: 4000 0027 6000 3184
# Declined: 4000 0000 0000 0002
# Insufficient funds: 4000 0000 0000 9995

# ================================================
# FEATURE FLAGS (Development)
# ================================================
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SENTRY=false
NEXT_PUBLIC_ENABLE_DEBUG=true
NEXT_PUBLIC_ENABLE_MOCK_API=false

# ================================================
# ANALYTICS & MONITORING (Development - Optional)
# ================================================
# Google Analytics (Use test property ID)
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_GTM_ID=

# Sentry (Use development DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=marifetbul
SENTRY_PROJECT=marifetbul-frontend-dev

# ================================================
# FILE UPLOAD CONFIGURATION (Development)
# ================================================
# For development, use 'local' or 'cloudinary' test account
NEXT_PUBLIC_UPLOAD_PROVIDER=cloudinary

# Cloudinary (Development Account)
# Sign up at: https://cloudinary.com/users/register/free
# Get credentials from: https://console.cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Cloudinary Upload Presets (Unsigned uploads)
# Create in Cloudinary Console: Settings > Upload > Upload Presets
# Preset Settings:
# - Signing Mode: Unsigned
# - Folder: marifetbul/packages (or marifetbul/portfolios)
# - Use filename: false
# - Unique filename: true
# - Overwrite: false
# - Resource type: Image
# - Access mode: Public
# - Format: Auto (JPG, PNG, WebP)
# - Quality: Auto
# - Transformations: Optional (resize, crop, etc.)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=marifetbul_packages

# Cloudinary Folders
# Organized by entity type for better management:
# - marifetbul/packages/     → Package images
# - marifetbul/portfolios/   → Portfolio images  
# - marifetbul/profiles/     → User profile pictures
# - marifetbul/blog/         → Blog post images
# - marifetbul/messages/     → Message attachments

# Cloudinary Limits (Free Tier)
# - Storage: 25 GB
# - Bandwidth: 25 GB/month
# - Transformations: 25 credits/month
# - Max file size: 10 MB (unsigned), 100 MB (signed)
# For higher limits, upgrade plan at: https://cloudinary.com/pricing

# AWS S3 (Development Bucket - Optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=marifetbul-dev

# ================================================
# DEVELOPMENT TOOLS
# ================================================
# Enable React DevTools
NEXT_PUBLIC_ENABLE_DEVTOOLS=true

# Enable verbose logging
NEXT_PUBLIC_LOG_LEVEL=debug

# API request timeout (ms)
NEXT_PUBLIC_API_TIMEOUT=30000

# ================================================
# DEVELOPMENT TEST CREDENTIALS
# ================================================
# These credentials are for development/testing only
# DO NOT use in production - set strong passwords via database
# Default admin user created by V1__init_schema.sql migration:
# Email: admin@marifetbul.com
# Password: Admin123!
# 
# PRODUCTION: Change admin password immediately after first login
# or create via secure admin setup process

# ================================================
# DATABASE (Not used by frontend, for reference)
# ================================================
# Backend database configuration (runs separately)
# DB_URL=jdbc:postgresql://localhost:5432/marifetbul_dev
# DB_USERNAME=postgres
# DB_PASSWORD=postgres

# ================================================
# REDIS (Not used by frontend, for reference)
# ================================================
# Backend cache configuration (runs separately)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ================================================
# ELASTICSEARCH (Not used by frontend, for reference)
# ================================================
# Backend search configuration (runs separately)
# ELASTICSEARCH_URIS=http://localhost:9200
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=

# ================================================
# NOTES
# ================================================
# 1. This file contains safe default values for local development
# 2. Never commit .env.local to version control (already in .gitignore)
# 3. For production, use .env.production.example as reference
# 4. Restart Next.js dev server after changing environment variables
# 5. Environment variables prefixed with NEXT_PUBLIC_ are exposed to browser
# 6. Non-prefixed variables are only available in Node.js environment

# ================================================
# QUICK START
# ================================================
# 1. Copy this file: cp .env.local.example .env.local
# 2. Start backend: cd marifetbul-backend && ./mvnw spring-boot:run
# 3. Start frontend: npm run dev
# 4. Open browser: http://localhost:3000
