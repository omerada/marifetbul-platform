# ============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT
# ============================================================================
# Copy this to .env.local for your local development setup
# .env.local is gitignored and won't be committed

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application Info
NEXT_PUBLIC_APP_NAME=MarifetBul (Dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0-dev
NEXT_PUBLIC_APP_ENV=development

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================

# Local Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# API Timeout Configuration
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_API_RETRY_ATTEMPTS=3

# ============================================================================
# DEVELOPMENT FEATURES
# ============================================================================

# Mock Service Worker (MSW) - Set to true to use mock data instead of real API
NEXT_PUBLIC_ENABLE_MSW=true

# Debug Mode - Enable verbose logging
NEXT_PUBLIC_ENABLE_DEBUG=true

# WebSocket Debug
NEXT_PUBLIC_WS_DEBUG=true

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Core Features
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SENTRY=false
NEXT_PUBLIC_ENABLE_WEBSOCKET=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_REAL_TIME=true

# Beta Features (Safe to enable in dev)
NEXT_PUBLIC_ENABLE_AI_RECOMMENDATIONS=true
NEXT_PUBLIC_ENABLE_VIDEO_CHAT=true
NEXT_PUBLIC_ENABLE_ADVANCED_SEARCH=true

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# Session Configuration
NEXT_PUBLIC_SESSION_TIMEOUT=3600000
SESSION_SECRET=dev-secret-key-change-in-production-min-32-chars

# CSRF Protection (can be disabled in dev)
NEXT_PUBLIC_CSRF_ENABLED=false

# Cookie Configuration
NEXT_PUBLIC_COOKIE_DOMAIN=localhost
NEXT_PUBLIC_COOKIE_SECURE=false
NEXT_PUBLIC_COOKIE_SAME_SITE=lax

# ============================================================================
# PERFORMANCE & CACHING
# ============================================================================

# Cache Configuration (shorter TTL for development)
NEXT_PUBLIC_CACHE_ENABLED=true
NEXT_PUBLIC_CACHE_TTL=60000
NEXT_PUBLIC_CACHE_MAX_SIZE=50

# Retry Configuration
NEXT_PUBLIC_RETRY_ENABLED=true
NEXT_PUBLIC_RETRY_MAX_ATTEMPTS=5
NEXT_PUBLIC_RETRY_TIMEOUT=30000

# WebSocket Configuration
NEXT_PUBLIC_WS_RECONNECT_INTERVAL=3000
NEXT_PUBLIC_WS_MAX_RECONNECT_ATTEMPTS=15
NEXT_PUBLIC_WS_HEARTBEAT_INTERVAL=20000

# ============================================================================
# MONITORING & ANALYTICS (Disabled in Dev)
# ============================================================================

# Google Analytics (Dev - Disabled)
# NEXT_PUBLIC_GA_TRACKING_ID=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Sentry Error Tracking (Dev - Disabled)
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# ============================================================================
# THIRD-PARTY INTEGRATIONS (Use Test Keys)
# ============================================================================

# Social Authentication (Test/Dev Keys)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_FACEBOOK_APP_ID=

# Payment Gateways (Test Mode)
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx

# Cloud Storage (Dev Bucket)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=marifetbul-dev
# AWS_S3_BUCKET=marifetbul-dev

# ============================================================================
# DATABASE (Backend Only - Not Used by Frontend)
# ============================================================================

# PostgreSQL (For reference)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marifetbul_dev

# Redis (For reference)
# REDIS_URL=redis://localhost:6379

# ============================================================================
# DEVELOPMENT NOTES
# ============================================================================

# 1. MSW (Mock Service Worker):
#    - Set NEXT_PUBLIC_ENABLE_MSW=true to use mock data
#    - Set NEXT_PUBLIC_ENABLE_MSW=false to use real backend
#    - Useful when backend is not running or for frontend-only development

# 2. Real Backend:
#    - Make sure Spring Boot backend is running on http://localhost:8080
#    - Database and Redis should be available
#    - Check backend logs for any errors

# 3. Environment Files:
#    - .env.local (this file) - Local development (gitignored)
#    - .env.staging - Staging environment
#    - .env.production - Production environment
#    - .env.example - Template file (committed to git)

# 4. To switch between MSW and real backend:
#    - MSW: NEXT_PUBLIC_ENABLE_MSW=true
#    - Real API: NEXT_PUBLIC_ENABLE_MSW=false

# ============================================================================
# QUICK START
# ============================================================================

# Option 1: Frontend development with mock data
# 1. Copy this file to .env.local
# 2. Set NEXT_PUBLIC_ENABLE_MSW=true
# 3. Run: npm run dev
# 4. No backend needed!

# Option 2: Full-stack development with real backend
# 1. Copy this file to .env.local
# 2. Set NEXT_PUBLIC_ENABLE_MSW=false
# 3. Start backend: cd marifetbul-backend && mvn spring-boot:run
# 4. Start frontend: npm run dev
# 5. Both must be running!

# ============================================================================
