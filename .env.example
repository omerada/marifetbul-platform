# ================================================
# MARIFETBUL - ENVIRONMENT CONFIGURATION
# ================================================
# Production-Ready Environment Variables
# Copy to .env.local for development

# ================================================
# APPLICATION CONFIGURATION
# ================================================
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=MarifetBul
NEXT_PUBLIC_APP_URL=https://marifetbul.com
NEXT_PUBLIC_BASE_URL=https://marifetbul.com

# ================================================
# BACKEND API CONFIGURATION
# ================================================
NEXT_PUBLIC_API_URL=https://api.marifetbul.com/api/v1

# ================================================
# FEATURE FLAGS
# ================================================
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SENTRY=true
NEXT_PUBLIC_ENABLE_DEBUG=false

# ================================================
# ANALYTICS & MONITORING (Production)
# ================================================
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxx
SENTRY_AUTH_TOKEN=
SENTRY_ORG=marifetbul
SENTRY_PROJECT=marifetbul-frontend

# ================================================
# DEVELOPMENT CONFIGURATION (Override in .env.local)
# ================================================
# NODE_ENV=development
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
# NEXT_PUBLIC_ENABLE_SENTRY=false
# NEXT_PUBLIC_ENABLE_DEBUG=true

# ================================================
# FILE UPLOAD CONFIGURATION
# ================================================
# Upload provider: 'cloudinary' | 'aws-s3' | 'local'
NEXT_PUBLIC_UPLOAD_PROVIDER=cloudinary

# Cloudinary Configuration (Recommended for production)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# AWS S3 Configuration (Alternative)
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your_bucket_name
