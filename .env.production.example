# Production Environment Configuration
# Copy to .env.production for production builds

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application Info
NEXT_PUBLIC_APP_NAME=MarifetBul
NEXT_PUBLIC_APP_URL=https://marifetbul.com
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_ENV=production

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================

# Production API URL (Replace with your actual production API)
NEXT_PUBLIC_API_URL=https://api.marifetbul.com/api/v1

# WebSocket URL (Replace with your actual WebSocket server)
NEXT_PUBLIC_WS_URL=wss://api.marifetbul.com/ws

# API Timeout Configuration
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_API_RETRY_ATTEMPTS=3

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# Session Configuration
NEXT_PUBLIC_SESSION_TIMEOUT=3600000
SESSION_SECRET=your-super-secret-session-key-min-32-chars

# CSRF Protection
NEXT_PUBLIC_CSRF_ENABLED=true

# Cookie Configuration
NEXT_PUBLIC_COOKIE_DOMAIN=.marifetbul.com
NEXT_PUBLIC_COOKIE_SECURE=true
NEXT_PUBLIC_COOKIE_SAME_SITE=strict

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Core Features
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SENTRY=true
NEXT_PUBLIC_ENABLE_WEBSOCKET=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_REAL_TIME=true

# Beta Features
NEXT_PUBLIC_ENABLE_AI_RECOMMENDATIONS=false
NEXT_PUBLIC_ENABLE_VIDEO_CHAT=false
NEXT_PUBLIC_ENABLE_ADVANCED_SEARCH=true

# Development Features (Disable in production)
NEXT_PUBLIC_ENABLE_MSW=false
NEXT_PUBLIC_ENABLE_DEBUG=false
NEXT_PUBLIC_WS_DEBUG=false

# ============================================================================
# PERFORMANCE & CACHING
# ============================================================================

# Cache Configuration
NEXT_PUBLIC_CACHE_ENABLED=true
NEXT_PUBLIC_CACHE_TTL=300000
NEXT_PUBLIC_CACHE_MAX_SIZE=100

# Retry Configuration
NEXT_PUBLIC_RETRY_ENABLED=true
NEXT_PUBLIC_RETRY_MAX_ATTEMPTS=3
NEXT_PUBLIC_RETRY_TIMEOUT=30000

# WebSocket Configuration
NEXT_PUBLIC_WS_RECONNECT_INTERVAL=5000
NEXT_PUBLIC_WS_MAX_RECONNECT_ATTEMPTS=10
NEXT_PUBLIC_WS_HEARTBEAT_INTERVAL=30000

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================

# Google Analytics
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=marifetbul-frontend
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SAMPLE_RATE=0.1

# LogRocket (Optional)
NEXT_PUBLIC_LOGROCKET_APP_ID=xxxxx/marifetbul

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================

# Social Authentication
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
NEXT_PUBLIC_FACEBOOK_APP_ID=xxxxxxxxxxxxx
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=xxxxxxxxxxxxx

# Payment Gateways
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
NEXT_PUBLIC_PAYPAL_CLIENT_ID=xxxxxxxxxxxxx

# Cloud Storage (AWS S3 / Cloudinary)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-preset
AWS_S3_BUCKET=marifetbul-prod
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxx

# Email Service
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
NEXT_PUBLIC_CONTACT_EMAIL=info@marifetbul.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@marifetbul.com

# ============================================================================
# SEO & SOCIAL
# ============================================================================

# SEO Configuration
NEXT_PUBLIC_META_TITLE=MarifetBul - Türkiye'nin Freelance Platformu
NEXT_PUBLIC_META_DESCRIPTION=Türkiye'nin en güvenilir freelance platformu. İş bulun, eleman kiralayın, projelerinizi gerçekleştirin.
NEXT_PUBLIC_META_KEYWORDS=freelance,iş ilanları,serbest çalışan,proje,hizmet

# Social Media
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/marifetbul
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/marifetbul
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/marifetbul
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/marifetbul

# Open Graph
NEXT_PUBLIC_OG_IMAGE=https://marifetbul.com/og-image.jpg
NEXT_PUBLIC_OG_TYPE=website
NEXT_PUBLIC_OG_LOCALE=tr_TR

# ============================================================================
# CDN & ASSETS
# ============================================================================

# CDN Configuration
NEXT_PUBLIC_CDN_URL=https://cdn.marifetbul.com
NEXT_PUBLIC_ASSETS_URL=https://assets.marifetbul.com

# Image Optimization
NEXT_PUBLIC_IMAGE_QUALITY=90
NEXT_PUBLIC_IMAGE_FORMATS=webp,avif

# ============================================================================
# DATABASE & BACKEND (Server-side only)
# ============================================================================

# PostgreSQL (For backend API)
DATABASE_URL=postgresql://user:password@host:5432/marifetbul_prod

# Redis (For caching)
REDIS_URL=redis://redis-host:6379

# ============================================================================
# RATE LIMITING
# ============================================================================

NEXT_PUBLIC_RATE_LIMIT_ENABLED=true
NEXT_PUBLIC_RATE_LIMIT_MAX_REQUESTS=100
NEXT_PUBLIC_RATE_LIMIT_WINDOW=60000

# ============================================================================
# CONTENT SECURITY
# ============================================================================

# Content Security Policy
NEXT_PUBLIC_CSP_REPORT_URI=https://marifetbul.report-uri.com/r/d/csp/enforce

# CORS Configuration
NEXT_PUBLIC_CORS_ORIGINS=https://marifetbul.com,https://www.marifetbul.com

# ============================================================================
# SEARCH & INDEXING
# ============================================================================

# Elasticsearch (For advanced search)
ELASTICSEARCH_URL=https://elasticsearch-host:9200
ELASTICSEARCH_API_KEY=xxxxxxxxxxxxx

# Algolia (Alternative search)
NEXT_PUBLIC_ALGOLIA_APP_ID=xxxxxxxxxxxxx
NEXT_PUBLIC_ALGOLIA_API_KEY=xxxxxxxxxxxxx
NEXT_PUBLIC_ALGOLIA_INDEX=marifetbul_prod

# ============================================================================
# NOTIFICATIONS
# ============================================================================

# Push Notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=xxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxx

# Firebase Cloud Messaging
NEXT_PUBLIC_FCM_SENDER_ID=xxxxxxxxxxxxx
FCM_SERVER_KEY=xxxxxxxxxxxxx

# ============================================================================
# LEGAL & COMPLIANCE
# ============================================================================

# GDPR Compliance
NEXT_PUBLIC_GDPR_ENABLED=true
NEXT_PUBLIC_COOKIE_CONSENT_VERSION=1.0

# Terms Version
NEXT_PUBLIC_TERMS_VERSION=1.0
NEXT_PUBLIC_PRIVACY_VERSION=1.0

# ============================================================================
# BUILD & DEPLOYMENT
# ============================================================================

# Build Configuration
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
ANALYZE=false

# Vercel Configuration (if using Vercel)
VERCEL_ENV=production
VERCEL_URL=marifetbul.vercel.app

# CI/CD Configuration
CI=true
SKIP_ENV_VALIDATION=false

# ============================================================================
# MISCELLANEOUS
# ============================================================================

# Timezone
TZ=Europe/Istanbul

# Language
NEXT_PUBLIC_DEFAULT_LOCALE=tr
NEXT_PUBLIC_SUPPORTED_LOCALES=tr,en

# Currency
NEXT_PUBLIC_DEFAULT_CURRENCY=TRY
NEXT_PUBLIC_SUPPORTED_CURRENCIES=TRY,USD,EUR

# Maintenance Mode
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_MAINTENANCE_MESSAGE=Sistem bakımda. Kısa süre içinde geri döneceğiz.

# Contact Information
NEXT_PUBLIC_COMPANY_NAME=MarifetBul Teknoloji A.Ş.
NEXT_PUBLIC_COMPANY_ADDRESS=İstanbul, Türkiye
NEXT_PUBLIC_COMPANY_PHONE=+90 XXX XXX XX XX
NEXT_PUBLIC_COMPANY_TAX_NUMBER=XXXXXXXXXX

# ============================================================================
# NOTES
# ============================================================================
# 1. Replace all xxxxx placeholders with actual values
# 2. Never commit .env.production to version control
# 3. Use environment variables in CI/CD pipeline
# 4. Validate all URLs before deployment
# 5. Test in staging environment first
# 6. Keep backup of working configuration
# 7. Use secrets management (AWS Secrets Manager, Azure Key Vault, etc.)
