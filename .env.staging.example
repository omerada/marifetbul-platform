# Staging Environment Configuration
# Copy to .env.staging for staging builds

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application Info
NEXT_PUBLIC_APP_NAME=MarifetBul (Staging)
NEXT_PUBLIC_APP_URL=https://staging.marifetbul.com
NEXT_PUBLIC_APP_VERSION=1.0.0-staging
NEXT_PUBLIC_APP_ENV=staging

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================

# Staging API URL
NEXT_PUBLIC_API_URL=https://api-staging.marifetbul.com/api/v1

# WebSocket URL
NEXT_PUBLIC_WS_URL=wss://api-staging.marifetbul.com/ws

# API Timeout Configuration
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_API_RETRY_ATTEMPTS=3

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# Session Configuration
NEXT_PUBLIC_SESSION_TIMEOUT=3600000
SESSION_SECRET=your-staging-secret-session-key-min-32-chars

# CSRF Protection
NEXT_PUBLIC_CSRF_ENABLED=true

# Cookie Configuration
NEXT_PUBLIC_COOKIE_DOMAIN=.staging.marifetbul.com
NEXT_PUBLIC_COOKIE_SECURE=true
NEXT_PUBLIC_COOKIE_SAME_SITE=lax

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Core Features
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SENTRY=true
NEXT_PUBLIC_ENABLE_WEBSOCKET=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_REAL_TIME=true

# Beta Features (Test in staging)
NEXT_PUBLIC_ENABLE_AI_RECOMMENDATIONS=true
NEXT_PUBLIC_ENABLE_VIDEO_CHAT=true
NEXT_PUBLIC_ENABLE_ADVANCED_SEARCH=true

# Development Features
NEXT_PUBLIC_ENABLE_DEBUG=true
NEXT_PUBLIC_WS_DEBUG=true

# ============================================================================
# PERFORMANCE & CACHING
# ============================================================================

# Cache Configuration (shorter TTL for testing)
NEXT_PUBLIC_CACHE_ENABLED=true
NEXT_PUBLIC_CACHE_TTL=60000
NEXT_PUBLIC_CACHE_MAX_SIZE=50

# Retry Configuration
NEXT_PUBLIC_RETRY_ENABLED=true
NEXT_PUBLIC_RETRY_MAX_ATTEMPTS=5
NEXT_PUBLIC_RETRY_TIMEOUT=30000

# WebSocket Configuration
NEXT_PUBLIC_WS_RECONNECT_INTERVAL=3000
NEXT_PUBLIC_WS_MAX_RECONNECT_ATTEMPTS=15
NEXT_PUBLIC_WS_HEARTBEAT_INTERVAL=20000

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================

# Google Analytics (Staging)
NEXT_PUBLIC_GA_TRACKING_ID=G-STAGING-XXX

# Sentry (Staging)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx-staging
NEXT_PUBLIC_SENTRY_ENVIRONMENT=staging
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1.0
NEXT_PUBLIC_SENTRY_REPLAYS_SAMPLE_RATE=1.0

# ============================================================================
# THIRD-PARTY INTEGRATIONS (Test Keys)
# ============================================================================

# Social Authentication (Test)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=test-google-client-id
NEXT_PUBLIC_FACEBOOK_APP_ID=test-facebook-app-id

# Payment Gateways (Test Mode)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Cloud Storage (Staging Bucket)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=marifetbul-staging
AWS_S3_BUCKET=marifetbul-staging

# ============================================================================
# SEO & SOCIAL
# ============================================================================

# SEO Configuration (Staging)
NEXT_PUBLIC_META_TITLE=MarifetBul Staging
NEXT_PUBLIC_META_DESCRIPTION=Staging environment for MarifetBul platform
NEXT_PUBLIC_META_ROBOTS=noindex,nofollow

# ============================================================================
# DATABASE & BACKEND (Server-side only)
# ============================================================================

# PostgreSQL (Staging)
DATABASE_URL=postgresql://user:password@host:5432/marifetbul_staging

# Redis (Staging)
REDIS_URL=redis://redis-staging:6379

# ============================================================================
# BUILD & DEPLOYMENT
# ============================================================================

# Build Configuration
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
ANALYZE=true

# Vercel Configuration
VERCEL_ENV=preview
VERCEL_URL=staging.marifetbul.vercel.app

# ============================================================================
# MISCELLANEOUS
# ============================================================================

# Maintenance Mode
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_MAINTENANCE_MESSAGE=Staging ortamı test için kullanılmaktadır.

# Timezone
TZ=Europe/Istanbul

# Language
NEXT_PUBLIC_DEFAULT_LOCALE=tr
NEXT_PUBLIC_SUPPORTED_LOCALES=tr,en
